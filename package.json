{
  "name": "phd-plan",
  "version": "1.0.0",
  "description": "五年博士买房计划 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac dmg",
    "build:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.phdplan.app",
    "productName": "买房计划",
    "files": [
      "plan-plan-fighting.html",
      "manifest.json",
      "sw.js",
      "icon.svg",
      ".nojekyll"
    ],
    "win": {
      "icon": "icon.svg",
      "target": ["portable"]
    },
    "mac": {
      "icon": "icon.svg",
      "target": ["dmg"]
    },
    "linux": {
      "icon": "icon.svg",
      "target": ["AppImage"]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
